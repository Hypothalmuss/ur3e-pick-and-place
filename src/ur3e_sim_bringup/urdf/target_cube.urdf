<?xml version="1.0"?>
<robot name="target_cube">
  <material name="orange">
    <color rgba="1 0.6 0 1"/>
  </material>

  <link name="base_link">
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.06 0.06 0.06"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.06 0.06"/>
      </geometry>
    </collision>
  </link>
</robot>
