<?xml version="1.0"?>
<robot name="table">
  <link name="table_top">
    <inertial>
      <mass value="50.0"/>
      <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.8 0.8 0.04"/>
      </geometry>
      <material name="wood">
        <color rgba="0.6 0.4 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.8 0.8 0.04"/>
      </geometry>
    </collision>
  </link>
  <link name="table_leg">
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.1 0.1 0.7"/>
      </geometry>
      <material name="metal">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.7"/>
      </geometry>
    </collision>
  </link>
  <joint name="top_to_leg" type="fixed">
    <parent link="table_top"/>
    <child link="table_leg"/>
    <origin xyz="0 0 -0.36" rpy="0 0 0"/>
  </joint>
</robot>
